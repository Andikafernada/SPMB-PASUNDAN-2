    <script>
        // --- LOGIKA 1: GACHA WANGSIT BANG JANGKRIK ---
        const jurusanData = [
            { id: "TKJ", desc: "Aura kabel UTP mengelilingimu. Cocok jadi penguasa jaringan & server!" },
            { id: "TPM", desc: "Tanganmu terbuat dari besi. Presisi CNC ada di dalam DNA-mu!" },
            { id: "TKR", desc: "Bau oli adalah parfummu. Mesin injeksi menunggumu!" },
            { id: "TSM", desc: "Jiwa *riding*-mu kuat. Tarikan gas roda dua adalah takdirmu!" },
            { id: "TAV", desc: "Mata kameramu tajam. Sutradara & ahli sinyal masa depan!" }
        ];

        let isSpinning = false;
        function putarWangsit() {
            if (isSpinning) return;
            isSpinning = true;
            
            const resultEl = document.getElementById('wangsit-result');
            const descEl = document.getElementById('wangsit-desc');
            const btn = document.getElementById('btn-gacha');
            
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Algoritma Bekerja...';
            btn.classList.add('opacity-75');
            descEl.innerText = "Membaca garis tangan digital...";

            let counter = 0;
            const spinInterval = setInterval(() => {
                // Tampilkan random jurusan cepat
                const randomJ = jurusanData[Math.floor(Math.random() * jurusanData.length)];
                resultEl.innerText = randomJ.id;
                counter++;

                if (counter > 20) {
                    clearInterval(spinInterval);
                    // Hasil Akhir
                    const finalJ = jurusanData[Math.floor(Math.random() * jurusanData.length)];
                    resultEl.innerText = finalJ.id;
                    resultEl.className = "font-display font-black text-3xl text-yellow-400 tracking-widest uppercase transform scale-110 transition-transform duration-300";
                    descEl.innerHTML = `<span class="text-white font-bold">Wangsit Bang Jangkrik:</span> ${finalJ.desc}`;
                    
                    btn.innerHTML = '<i class="fas fa-redo"></i> Acak Ulang';
                    btn.classList.remove('opacity-75');
                    isSpinning = false;
                }
            }, 100);
        }

        // --- LOGIKA 2: FINGERPRINT SCANNER ---
        const btnFinger = document.getElementById('btn-fingerprint');
        const formScan = document.getElementById('form-scan');
        const idInput = document.getElementById('id_input');
        const instruction = document.getElementById('scan-instruction');
        
        let scanTimer;
        const requiredScanTime = 1500; // 1.5 detik ditahan

        function startScan(e) {
            e.preventDefault(); // Mencegah klik biasa
            if(idInput.value.trim() === '') {
                idInput.classList.add('border-red-500', 'animate-shake');
                setTimeout(() => idInput.classList.remove('border-red-500', 'animate-shake'), 500);
                instruction.innerText = "ISI ID DULU, BOS!";
                instruction.classList.add('text-red-400');
                return;
            }

            instruction.innerText = "MEMINDAI... TAHAN TERUS";
            instruction.classList.remove('text-red-400');
            instruction.classList.add('text-blue-400', 'animate-pulse');
            btnFinger.classList.add('scanning', 'bg-slate-800', 'border-blue-500', 'text-blue-500');
            btnFinger.style.transform = 'scale(0.95)';

            // Jika ditahan sampai waktu habis, submit form
            scanTimer = setTimeout(() => {
                instruction.innerText = "AKSES DITERIMA!";
                instruction.classList.replace('text-blue-400', 'text-emerald-400');
                btnFinger.classList.replace('text-blue-500', 'text-emerald-500');
                btnFinger.classList.replace('border-blue-500', 'border-emerald-500');
                // Vibrate jika di HP
                if(navigator.vibrate) navigator.vibrate([200, 100, 200]);
                
                setTimeout(() => formScan.submit(), 500);
            }, requiredScanTime);
        }

        function stopScan() {
            clearTimeout(scanTimer);
            if(instruction.innerText !== "AKSES DITERIMA!") {
                instruction.innerText = "Tahan / Hold untuk Verifikasi";
                instruction.classList.remove('text-blue-400', 'animate-pulse');
                btnFinger.classList.remove('scanning', 'bg-slate-800', 'border-blue-500', 'text-blue-500');
                btnFinger.style.transform = 'scale(1)';
            }
        }

        // Support untuk layar sentuh HP dan klik Mouse PC
        btnFinger.addEventListener('mousedown', startScan);
        btnFinger.addEventListener('touchstart', startScan, {passive: false});
        
        btnFinger.addEventListener('mouseup', stopScan);
        btnFinger.addEventListener('mouseleave', stopScan);
        btnFinger.addEventListener('touchend', stopScan);
        btnFinger.addEventListener('touchcancel', stopScan);
    </script>
