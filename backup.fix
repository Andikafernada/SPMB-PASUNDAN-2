<?php
/**
 * LANDING PAGE - SPMB SMK Pasundan 2 Bandung
 * Fitur: Dark Mode, Gamifikasi Kuis, Looping Video, E-Magazine (Pop-up View), Maskot Bang Jangkrik
 */
include 'config.php';

// Statistik pendaftar
$total_siswa = 0;
$r = mysqli_query($conn, "SELECT COUNT(*) as n FROM siswa");
if ($r) $total_siswa = mysqli_fetch_assoc($r)['n'] ?? 0;

// Data gelombang dari database
$gel_list = [];
$rg = mysqli_query($conn, "SELECT * FROM gelombang ORDER BY biaya ASC");
while ($g = mysqli_fetch_assoc($rg)) $gel_list[] = $g;
if (empty($gel_list)) {
    $gel_list = [
        ['id'=>1,'nama'=>'Gelombang 1','biaya'=>150000, 'tgl_mulai'=>'2026-01-01'],
        ['id'=>2,'nama'=>'Gelombang 2','biaya'=>175000, 'tgl_mulai'=>'2026-03-01'],
        ['id'=>3,'nama'=>'Gelombang 3','biaya'=>200000, 'tgl_mulai'=>'2026-05-01'],
    ];
}

// WhatsApp & YouTube ID dari .env atau fallback
$wa = $_ENV['WA_CONTACT'] ?? '628123456789';
$yt = $_ENV['YOUTUBE_VIDEO_ID'] ?? 'YOUR_VIDEO_ID';

// Cek Status Handler
$status = null;
$status_err = '';
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['cek_status'])) {
    $kode = trim(mysqli_real_escape_string($conn, $_POST['kode'] ?? ''));
    if ($kode) {
        $stmt = mysqli_prepare($conn, "SELECT id_siswa, id_pendaftaran, nama_lengkap, jurusan, asal_sekolah, status_siswa, status_pendaftaran, status_bayar, nik, nisn, no_hp FROM siswa WHERE id_pendaftaran=? LIMIT 1");
        mysqli_stmt_bind_param($stmt, "s", $kode);
        mysqli_stmt_execute($stmt);
        $rs = mysqli_stmt_get_result($stmt);
        if ($rs && mysqli_num_rows($rs) > 0) {
            $status = mysqli_fetch_assoc($rs);
            // Cek kelengkapan data wajib
            $wajib = [$status['nik'], $status['nisn'], $status['no_hp'], $status['jurusan']];
            $status['data_lengkap'] = !in_array('', $wajib) && !empty(array_filter($wajib));
        } else {
            $status_err = 'ID Pendaftaran tidak ditemukan. Pastikan ID yang dimasukkan benar.';
        }
        mysqli_stmt_close($stmt);
    }
    $_SESSION['cek_status'] = $status;
    $_SESSION['cek_status_err'] = $status_err;
    header('Location: ' . $_SERVER['PHP_SELF'] . '?status=ok#cek');
    exit;
}

// Ambil hasil redirect session
if (isset($_GET['status']) && $_GET['status'] === 'ok') {
    $status = $_SESSION['cek_status'] ?? null;
    $status_err = $_SESSION['cek_status_err'] ?? '';
    unset($_SESSION['cek_status'], $_SESSION['cek_status_err']);
}
?>
