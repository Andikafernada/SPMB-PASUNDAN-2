  <div class="mb-3 px-5 py-3 bg-white dark:bg-slate-800 rounded-2xl rounded-br-none shadow-xl shadow-blue-900/20 border border-slate-100 dark:border-slate-700 transform origin-bottom-right transition-all duration-300 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 max-w-xs">
    <p class="text-sm text-slate-700 dark:text-slate-300 font-medium leading-snug">
      <span class="font-bold text-indigo-600 dark:text-indigo-400">Wangsit hari ini:</span><br>
      Ada yang bingung mau daftar? Sini ngobrol bareng ahlinya! 🔮🦗
    </p>
  </div>
  <a href="https://wa.me/<?= $wa ?>?text=Halo%20Bang%20Jangkrik,%20saya%20mau%20tanya%20soal%20SPMB" target="_blank"
     class="relative w-16 h-16 bg-gradient-to-tr from-indigo-600 to-purple-600 rounded-full shadow-lg shadow-purple-500/30 flex items-center justify-center text-white transition hover:scale-110 active:scale-95 border-2 border-white dark:border-slate-800 overflow-hidden">
    <span class="text-3xl select-none">🦗</span>
    <span class="absolute top-0 right-0 w-4 h-4 bg-green-500 border-2 border-white dark:border-slate-800 rounded-full"></span>
  </a>
</div>

<script>
// CONTROLLER DARK MODE
const html = document.documentElement;
const themeToggleBtn = document.getElementById('theme-toggle');
const themeIcon = document.getElementById('theme-icon');

function updateTheme(isDark) {
  if (isDark) {
    html.classList.add('dark');
    themeIcon.textContent = '☀️';
  } else {
    html.classList.remove('dark');
    themeIcon.textContent = '🌙';
  }
}

const userPrefersDark = localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches);
updateTheme(userPrefersDark);

themeToggleBtn.addEventListener('click', () => {
  const isDark = html.classList.contains('dark');
  updateTheme(!isDark);
  localStorage.theme = !isDark ? 'dark' : 'light';
});

// CONTROLLER MODAL PDF
function openPdfModal() {
  const pdfUrl = "public/assets/emagazine-p2.pdf";
  document.getElementById('pdf-frame').src = pdfUrl;
  document.getElementById('pdf-modal').classList.remove('hidden');
}

function closePdfModal() {
  document.getElementById('pdf-modal').classList.add('hidden');
  document.getElementById('pdf-frame').src = ""; // Stop processing iframe when closed
}

// GAMIFIKASI KUIS MINAT INTERAKTIF
const quizData = [
  {
    question: "Apa hal yang paling bikin kamu penasaran?",
    options: [
      { text: "Bongkar pasang isi komputer / Jaringan", score: { TJKT: 2, TE: 1 } },
      { text: "Ngoprek mesin motor, bikin kenceng", score: { TSM: 2, TM: 1 } },
      { text: "Bikin robot atau alat elektronik canggih", score: { TE: 2, TJKT: 1 } },
      { text: "Dunia mobil, modifikasi & mesinnya", score: { TO: 2, TM: 1 } }
    ]
  },
  {
    question: "Kalau ada barang elektronik rusak di rumah, kamu biasanya...",
    options: [
      { text: "Cek komponen bagian dalam / Solder ulang", score: { TE: 2 } },
      { text: "Bongkar casing & utak-atik mekaniknya", score: { TM: 2, TSM: 1 } },
      { text: "Cari tutorial perbaikannya di YouTube (Masalah OS/Software)", score: { TJKT: 2 } },
      { text: "Panggil tukang servis tapi diperhatikan cara kerjanya", score: { TO: 1, TSM: 1 } }
    ]
  }
];

let currentQuestion = 0;
let scores = { TJKT: 0, TE: 0, TM: 0, TO: 0, TSM: 0 };
const qContainer = document.getElementById('quiz-content');
const qProgress = document.getElementById('quiz-progress');

function renderQuestion() {
  if (currentQuestion >= quizData.length) {
    showResult();
    return;
  }
  
  const q = quizData[currentQuestion];
  qProgress.style.width = ((currentQuestion + 1) / (quizData.length + 1)) * 100 + "%";
  
  let htmlContent = `<h3 class="font-outfit text-2xl font-bold text-slate-900 dark:text-white mb-6">${q.question}</h3><div class="grid sm:grid-cols-2 gap-4">`;
  
  q.options.forEach((opt) => {
    htmlContent += `<button onclick='answerQuiz(${JSON.stringify(opt.score)})' class="quiz-card p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 hover:border-blue-500 dark:hover:border-blue-500 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-medium text-left">
              ${opt.text}
             </button>`;
  });
  htmlContent += `</div>`;
  qContainer.innerHTML = htmlContent;
}

window.answerQuiz = function(scoreData) {
  for (let key in scoreData) {
    scores[key] += scoreData[key];
  }
  currentQuestion++;
  renderQuestion();
}

function showResult() {
  qProgress.style.width = "100%";
  let topMajor = Object.keys(scores).reduce((a, b) => scores[a] > scores[b] ? a : b);
  
  let desc = {
    'TJKT': 'Wah, kamu berbakat jadi IT Engineer / Network Admin! Jurusan **Teknik Jaringan & Telekomunikasi** cocok banget buat kamu.',
    'TE': 'Pola pikir logismu sinkron sekali dengan **Teknik Elektronika**. Kamu calon inovator IoT & Robotika masa depan!',
    'TM': 'Suka hal teknis presisi & manufaktur baja? **Teknik Mesin** adalah jalan karir terbaikmu.',
    'TO': 'Darah otomotif mengalir kuat di nadimu! Masuk **Teknik Otomotif** dan rancang kesuksesanmu.',
    'TSM': 'Spesialis mesin motor premium & injeksi! Asah keahlian mekanik profesionalmu di **Teknik Sepeda Motor**.'
  };

  qContainer.innerHTML = `
    <div class="text-center animate-[pulse-dot_0.5s_ease-out]">
      <div class="text-5xl mb-4">🎉</div>
      <h3 class="font-outfit text-2xl font-black text-slate-900 dark:text-white mb-2">Rekomendasi Jurusan: ${topMajor}</h3>
      <p class="text-slate-600 dark:text-slate-300 mb-6">${desc[topMajor].replace(/\*\*(.*?)\*\*/g, '<strong class="text-blue-600 dark:text-blue-400">$1</strong>')}</p>
      <a href="public/daftar.php" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition inline-block shadow-md">Gas Daftar Sekarang</a>
      <button onclick="resetQuiz()" class="px-4 py-3 text-slate-400 hover:text-slate-600 dark:hover:text-white text-sm underline mt-3 block mx-auto">Ulangi Kuis</button>
    </div>
  `;
}

window.resetQuiz = function() {
  currentQuestion = 0;
  scores = { TJKT: 0, TE: 0, TM: 0, TO: 0, TSM: 0 };
  renderQuestion();
}

// Jalankan kuis saat pertama dimuat
renderQuestion();
</script>
</body>
</html>
